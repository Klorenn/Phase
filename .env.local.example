# Copia este archivo a `.env.local` y rellena el valor (Next.js carga `.env.local` al arrancar).
#
# Servidor: carpeta escribible para JSON (faucet, listados, alias). En Vercel, por defecto se usa /tmp.
# PHASE_SERVER_DATA_DIR=

# Enlace Stellar Expert para PHASELQ (asset testnet). Por defecto: PHASELQ + issuer GAXR… (SAC distinto al legado PHASERLIQ).
# NEXT_PUBLIC_PHASER_LIQ_EXPERT_URL=  (override completo; si no, se arma con NEXT_PUBLIC_CLASSIC_LIQ_*)
# (No uses PHASER_LIQ_EXPERT_URL para enlaces en UI: en Next.js no llega al cliente y rompe hydration.)
#
# URL canónica del sitio (Open Graph / metadataBase). En Vercel producción suele ser:
# NEXT_PUBLIC_SITE_URL=https://www.phasee.xyz
# Al compilar el WASM, puedes fijar la base de `token_uri()` (debe terminar en /):
#   PHASE_METADATA_BASE_URL=https://tu-dominio-o-ngrok.app/api/metadata/ cargo build --target wasm32-unknown-unknown --release
# Si no se define, el contrato usa https://www.phasee.xyz/api/metadata/
# `token_metadata()` on-chain usa las mismas reglas de nombre/descripción/imagen que ese JSON, pero sin HTTP;
# la imagen en cadena puede ir vacía mientras el GET a /api/metadata/[id] sigue resolviendo OG/sitio.
# Imagen social absoluta opcional (si no, se usa {SITE}/og-phase.png):
# NEXT_PUBLIC_OG_IMAGE_URL=https://www.phasee.xyz/og-phase.png
#
# Opcional: habilita pintar/subir archivo en Forja (servidor). Déjalo vacío para desactivar.
PINATA_JWT=

# PINATA_API_JWT=

# ─── PHASELQ (contrato Soroban / SAC) ─────────────────────────────────────
# IMPORTANTE: aquí van IDs de contrato Soroban (prefijo C…, 56 caracteres).
# NO pongas tu dirección de wallet Freighter (G…): provoca "Invalid contract ID" en el SDK.
# Salida típica: stellar contract deploy … → Contract ID: CD…
# Nombre on-chain recomendado: Phase Liquidity Token · símbolo PHASELQ · 7 decimales.
# El cliente lee NEXT_PUBLIC_*; el servidor (faucet) puede usar TOKEN_CONTRACT_ID o MOCK_TOKEN_ID.
#
# Si cambias el SAC respecto al contrato PHASE desplegado (NFT), redeploy de phase-protocol con
# initialize(..., authorizedToken = tu SAC PHASELQ) y actualiza NEXT_PUBLIC_PHASE_PROTOCOL_ID.
#
# Debe coincidir con el SAC del asset clásico (mismo code+issuer que NEXT_PUBLIC_CLASSIC_* abajo):
# - Stellar Expert → Issuer (G…) → Assets → "Contract ID" del PHASELQ (no confundir con PHASERLIQ legado).
# - Si aún no existe el SAC: stellar contract asset deploy --asset PHASELQ:GAXR… --network testnet
#   (sustituye GAXR… por tu issuer). El ID que devuelve es el único válido para estas variables.
NEXT_PUBLIC_PHASER_TOKEN_ID=
# PHASER_TOKEN_ID=   (solo servidor; la UI usa NEXT_PUBLIC_* para el mismo valor)
# Escaneo bóveda NFT (GET /api/wallet/phase-nfts): máximo token id a revisar, concurrencia owner_of, concurrencia al armar metadata.
# PHASE_NFT_WALLET_SCAN_CAP=5000
# PHASE_NFT_WALLET_SCAN_CONCURRENCY=8
# PHASE_NFT_WALLET_METADATA_CONCURRENCY=4
#
# Contrato núcleo PHASE (settle / NFT utilitario SEP-20).
# La UI (SSR + cliente) solo lee NEXT_PUBLIC_*; si solo defines PHASE_PROTOCOL_ID, el navegador usará el default del repo y verás hydration mismatch.
# Si lo dejas vacío, se usa `DEFAULT_PHASE_CONTRACT` en lib/phase-contract-defaults.ts (testnet de referencia del repo).
NEXT_PUBLIC_PHASE_PROTOCOL_ID=
# PHASE_PROTOCOL_ID=   (opcional: solo rutas API / scripts; duplica el mismo C… en NEXT_PUBLIC_ para desarrollo local)
NEXT_PUBLIC_TOKEN_CONTRACT_ID=
# TOKEN_CONTRACT_ID=
# MOCK_TOKEN_ID=

# Forge Oracle (POST /api/forge-agent): lore (texto) Gemini + imagen.
# Imagen: si defines NANOBANANA_API_KEY (Bearer desde nanobananaapi.ai), se usa api.nanobananaapi.ai (TEXTTOIAMGE 1:1 + poll);
#   callBackUrl por defecto: {origen}/api/webhooks/nanobanana — o fija NANOBANANA_CALLBACK_URL en producción.
# NANOBANANA_API_KEY=
# NANOBANANA_CALLBACK_URL=https://tu-dominio.com/api/webhooks/nanobanana
# Lore / imagen Gemini (respaldo): claves deben ser tipo AIza… (Google AI Studio). No mezclar con otras APIs en GOOGLE_AI_STUDIO_API_KEY.
# GOOGLE_AI_STUDIO_API_KEY=
# GEMINI_API_KEY=
# Modelo lore (texto); por defecto gemini-3-flash. Cadena de fallback en código si uno falla.
# GEMINI_MODEL=gemini-3-flash
# Modelo imagen (Nano Banana 2); por defecto gemini-3.1-flash-image-preview
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# REST: v1beta por defecto; override: GEMINI_API_VERSION=v1 | v1beta
# GEMINI_API_VERSION=v1beta
# Si Nano Banana devuelve 429/cuota: por defecto se usa Pollinations para la imagen. Para forzar error: 1
# FORGE_DISABLE_POLLINATIONS_FALLBACK=

# Faucet (POST /api/faucet) — elige UNA estrategia:
#
# A) Mint (SAC / SEP-41): ADMIN_SECRET_KEY = secret del **Issuer** del asset PHASELQ (G… = NEXT_PUBLIC_CLASSIC_LIQ_ISSUER).
#    No uses el secret del “distribuidor” de la app: en el Stellar Asset Contract solo el issuer autoriza mint;
#    si firmas con otra cuenta suele fallar la invocación (p. ej. ihf_trapped). Mantén ≥5–10 XLM en esa cuenta.
#
# B) Transfer (recomendado si el issuer no debe tocar el servidor): FAUCET_DISTRIBUTOR_SECRET_KEY = cuenta con PHASELQ
#    ya acuñada (p. ej. genesis al distributor). Si esta variable está definida, el faucet ignora mint y hace
#    transfer(distribuidor → usuario). Prioridad: si existen ambas, gana el modo transfer.
ADMIN_SECRET_KEY=
# FAUCET_DISTRIBUTOR_SECRET_KEY=
# Opcional: ventana mínima entre mints por wallet e IP (ms). Por defecto 6h. 0 = sin espera entre aciertos.
# FAUCET_COOLDOWN_MS=21600000
# Desactivar límite (solo testnet local): FAUCET_DISABLE_RATE_LIMIT=1

# ─── PHASELQ (asset clásico para Freighter) ────────────────────────────────
# Para que se vea/retenga como asset en Freighter, usa un asset clásico (trustline).
# El issuer firma pagos bootstrap en `POST /api/classic-liq`.
CLASSIC_LIQ_ASSET_CODE=PHASELQ
CLASSIC_LIQ_ISSUER_SECRET=
# G… del distribuidor (pago clásico desde issuer). Si vacío, el script usa la G de FAUCET_DISTRIBUTOR_SECRET_KEY.
# CLASSIC_LIQ_DISTRIBUTOR_PUBLIC=
# Alias opcional (misma G que arriba):
# FAUCET_DISTRIBUTOR_PUBLIC_KEY=
# Cantidad del pago Issuer→distribuidor: `npm run classic:issuer-to-distributor` (default 100000.0000000)
# CLASSIC_LIQ_ISSUER_PAYMENT_AMOUNT=100000.0000000
# Host sin https:// (máx. 32 chars). Por defecto: host de NEXT_PUBLIC_SITE_URL o www.phasee.xyz
# CLASSIC_LIQ_ISSUER_HOME_DOMAIN=www.phasee.xyz
# Monto de bootstrap al habilitar trustline (7 decimales, string)
CLASSIC_LIQ_BOOTSTRAP_AMOUNT=10.0000000
# Variables públicas para mostrar/activar trustline desde UI.
# Preferí PHASELQ aquí; si el asset clásico sigue siendo PHASERLIQ en testnet, la UI igual muestra «PHASELQ» al leer el símbolo del SAC.
NEXT_PUBLIC_CLASSIC_LIQ_ASSET_CODE=PHASELQ
NEXT_PUBLIC_CLASSIC_LIQ_ISSUER=
# Icono/metadata en Freighter y Stellar Expert: cada cuenta emisora del asset debe tener en Horizon
# home_domain = host donde vive este proyecto (p. ej. www.phasee.xyz), sin https://.
# Así indexadores descargan https://TU_DOMINIO/.well-known/stellar.toml (SEP-0001).
# Si aún hay trustlines al emisor legado GAXR…, firma set_options con la clave de ESE emisor (desde la raíz del repo):
#   cd scripts && CLASSIC_LIQ_ISSUER_SECRET=<secret GAXR> npm run set:issuer-home-domain
# Si tu shell ya está en la carpeta scripts/, omite el cd: CLASSIC_LIQ_ISSUER_SECRET=<secret GAXR> npm run set:issuer-home-domain
# El TOML publicado incluye [[CURRENCIES]] para emisor de env y el legado cuando difieren.

# ─── Script reset testnet (issuer + distribuidor + PHASELQ) ───────────────
# npm run reset:phase  →  scripts/reset-phase.ts (imprime .env y comando `stellar contract asset deploy`).
# Opcional: monto clásico al distribuidor (7 decimales). Default 1000000.0000000
# RESET_PHASE_MINT_AMOUNT=1000000.0000000
# Código del asset: default PHASELQ en `reset-phase.ts`. Override solo si usas otro código on-chain.
# RESET_PHASE_ASSET_CODE=PHASERLIQ
