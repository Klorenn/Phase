# Copia este archivo a `.env.local` y rellena el valor (Next.js carga `.env.local` al arrancar).
#
# Servidor: carpeta escribible para JSON (faucet, listados, alias). En Vercel, por defecto se usa /tmp.
# PHASE_SERVER_DATA_DIR=

# Enlace Stellar Expert para PHASERLIQ (asset testnet). Por defecto usa el asset oficial del proyecto.
# NEXT_PUBLIC_PHASER_LIQ_EXPERT_URL=
# PHASER_LIQ_EXPERT_URL=
#
# URL canónica del sitio (Open Graph / metadataBase). En Vercel producción suele ser:
# NEXT_PUBLIC_SITE_URL=https://www.phasee.xyz
# Imagen social absoluta opcional (si no, se usa {SITE}/og-phase.png):
# NEXT_PUBLIC_OG_IMAGE_URL=https://www.phasee.xyz/og-phase.png
#
# Opcional: habilita pintar/subir archivo en Forja (servidor). Déjalo vacío para desactivar.
PINATA_JWT=

# PINATA_API_JWT=

# ─── PHASER_LIQ (contrato Soroban) ─────────────────────────────────────────
# IMPORTANTE: aquí van IDs de contrato Soroban (prefijo C…, 56 caracteres).
# NO pongas tu dirección de wallet Freighter (G…): provoca "Invalid contract ID" en el SDK.
# Salida típica: stellar contract deploy … → Contract ID: CD…
# Nombre on-chain recomendado: Phase Liquidity Token · símbolo PHASER_LIQ · 7 decimales.
# El cliente lee NEXT_PUBLIC_*; el servidor (faucet) puede usar TOKEN_CONTRACT_ID o MOCK_TOKEN_ID.
#
# Debe coincidir con el SAC del asset clásico (mismo code+issuer que NEXT_PUBLIC_CLASSIC_* abajo):
# - Stellar Expert → busca el Issuer (G…) → Assets → enlace "Contract ID" del PHASERLIQ.
# - Si aún no existe el contrato envuelto: stellar contract asset deploy --asset PHASERLIQ:GAXR… --network testnet
#   (sustituye GAXR… por tu issuer). El ID que devuelve es el único válido para estas variables.
NEXT_PUBLIC_PHASER_TOKEN_ID=
# PHASER_TOKEN_ID=
# Contrato núcleo PHASE (settle / NFT utilitario SEP-20):
NEXT_PUBLIC_PHASE_PROTOCOL_ID=
# PHASE_PROTOCOL_ID=
NEXT_PUBLIC_TOKEN_CONTRACT_ID=
# TOKEN_CONTRACT_ID=
# MOCK_TOKEN_ID=

# Forge Oracle (POST /api/forge-agent): lore vía Gemini; imagen vía Pollinations (sin clave).
# Sin GEMINI_API_KEY el endpoint responde 503 antes del paywall x402.
# GEMINI_API_KEY=

# Faucet (POST /api/faucet) — elige UNA estrategia:
#
# A) Mint (SAC / SEP-41): ADMIN_SECRET_KEY = secret del **Issuer** del asset PHASERLIQ (G… = NEXT_PUBLIC_CLASSIC_LIQ_ISSUER).
#    No uses el secret del “distribuidor” de la app: en el Stellar Asset Contract solo el issuer autoriza mint;
#    si firmas con otra cuenta suele fallar la invocación (p. ej. ihf_trapped). Mantén ≥5–10 XLM en esa cuenta.
#
# B) Transfer (recomendado si el issuer no debe tocar el servidor): FAUCET_DISTRIBUTOR_SECRET_KEY = cuenta con PHASERLIQ
#    ya acuñada (p. ej. genesis al distributor). Si esta variable está definida, el faucet ignora mint y hace
#    transfer(distribuidor → usuario). Prioridad: si existen ambas, gana el modo transfer.
ADMIN_SECRET_KEY=
# FAUCET_DISTRIBUTOR_SECRET_KEY=
# Opcional: ventana mínima entre mints por wallet e IP (ms). Por defecto 6h. 0 = sin espera entre aciertos.
# FAUCET_COOLDOWN_MS=21600000
# Desactivar límite (solo testnet local): FAUCET_DISABLE_RATE_LIMIT=1

# ─── PHASER_LIQ (asset clásico para Freighter) ─────────────────────────────
# Para que se vea/retenga como asset en Freighter, usa un asset clásico (trustline).
# El issuer firma pagos bootstrap en `POST /api/classic-liq`.
CLASSIC_LIQ_ASSET_CODE=PHASERLIQ
CLASSIC_LIQ_ISSUER_SECRET=
# G… del distribuidor (pago clásico desde issuer). Si vacío, el script usa la G de FAUCET_DISTRIBUTOR_SECRET_KEY.
# CLASSIC_LIQ_DISTRIBUTOR_PUBLIC=
# Cantidad del pago Issuer→distribuidor: `npm run classic:issuer-to-distributor` (default 100000.0000000)
# CLASSIC_LIQ_ISSUER_PAYMENT_AMOUNT=100000.0000000
# Host sin https:// (máx. 32 chars). Por defecto: host de NEXT_PUBLIC_SITE_URL o www.phasee.xyz
# CLASSIC_LIQ_ISSUER_HOME_DOMAIN=www.phasee.xyz
# Monto de bootstrap al habilitar trustline (7 decimales, string)
CLASSIC_LIQ_BOOTSTRAP_AMOUNT=10.0000000
# Variables públicas para mostrar/activar trustline desde UI.
NEXT_PUBLIC_CLASSIC_LIQ_ASSET_CODE=PHASERLIQ
NEXT_PUBLIC_CLASSIC_LIQ_ISSUER=
# Icono/metadata en Freighter: la cuenta emisora del asset (G… arriba) debe tener en Horizon
# home_domain = host donde vive este proyecto (p. ej. www.phasee.xyz), sin https://.
# Así la wallet descarga https://TU_DOMINIO/.well-known/stellar.toml y el campo image= del token.
