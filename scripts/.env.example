# PHASE Protocol - Environment Configuration
# Copia este archivo a .env y rellena con tus valores

# ============================================
# NETWORK CONFIGURATION
# ============================================
# Testnet RPC endpoint
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Testnet passphrase (pública, no es secreto)
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ============================================
# CONTRACT ADDRESSES (se llenan después del deploy)
# ============================================
# Mock Token Contract ID (después de desplegar)
MOCK_TOKEN_ID=

# Phase Protocol Contract ID (después de desplegar)
PHASE_PROTOCOL_ID=

# ============================================
# TOKEN CONFIGURATION
# ============================================
# Decimales del token (Stellar usa 7 por defecto)
TOKEN_DECIMALS=7

# Cantidad requerida para PHASE (en la unidad más pequeña)
# 10000000 = 1.0 token con 7 decimales
REQUIRED_AMOUNT=10000000

# Nombre y símbolo del token mock
TOKEN_NAME=Mock Test Token
TOKEN_SYMBOL=MOCK

# ============================================
# WALLET CONFIGURATION
# ============================================
# Tu dirección de Freighter (pública)
# Ejemplo: GDQX...ABC1
FREIGHTER_PUBLIC_KEY=

# ============================================
# OPTIONAL: Auto-deploy configuration
# ============================================
# Si tienes una secret key para testing (solo testnet!)
# DEJAR VACÍO si usas Freighter para firmar
# TESTING_SECRET_KEY=
