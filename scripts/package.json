{
  "name": "phase-protocol-scripts",
  "version": "0.1.0",
  "description": "Scripts de interacción con contratos PHASE Protocol",
  "type": "module",
  "scripts": {
    "diagnose": "cd .. && npm run diagnose",
    "build:token": "cd ../contracts/mock-token && cargo build --target wasm32-unknown-unknown --release",
    "build:phase": "cd ../contracts/phase-protocol && cargo build --target wasm32v1-none --release",
    "build:all": "npm run build:token && npm run build:phase",
    "optimize:token": "stellar contract optimize --wasm ../contracts/mock-token/target/wasm32-unknown-unknown/release/mock_token.wasm --wasm-out ../contracts/mock-token/target/wasm32-unknown-unknown/release/mock_token.optimized.wasm",
    "optimize:phase": "stellar contract optimize --wasm ../contracts/phase-protocol/target/wasm32v1-none/release/phase_protocol.wasm --wasm-out ../contracts/phase-protocol/target/wasm32v1-none/release/phase_protocol.optimized.wasm",
    "optimize:all": "npm run optimize:token && npm run optimize:phase",
    "compile": "npm run build:all && npm run optimize:all",
    "deploy:token": "tsx deploy-token.ts",
    "setup:token": "tsx setup_token.ts",
    "deploy:phase": "tsx deploy-phase.ts",
    "interact": "tsx interact.ts",
    "issue:sac": "tsx issue-sac-token.ts",
    "setup:phase-v2": "tsx setup-phase-v2.ts",
    "set:issuer-home-domain": "tsx set-issuer-home-domain.ts",
    "issuer-to-distributor": "tsx issuer-pay-distributor.ts",
    "distributor-trust-and-pay": "tsx distributor-trust-and-payment.ts",
    "reset:phase": "tsx reset-phase.ts"
  },
  "dependencies": {
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^12.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
